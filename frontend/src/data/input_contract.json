{
  "input_contract_version": "2.0.0",
  "contract_scope": "verdict_engine_input",
  "purpose": "Defines the normalized input required by the price-check engine before evaluation.",
  "required_fields": [
    "family_id",
    "variant_code",
    "ask_price",
    "user_intent"
  ],
  "optional_fields": [
    "spot_price_per_g_fine",
    "currency",
    "quantity",
    "source",
    "raw_title",
    "ocr_text"
  ],
  "field_definitions": {
    "family_id": {
      "type": "string",
      "constraints": [
        "must_exist_in_catalog"
      ]
    },
    "variant_code": {
      "type": "string",
      "constraints": [
        "must_exist_in_family_variants"
      ]
    },
    "ask_price": {
      "type": "number",
      "description": "Total price of the lot. Not the unit price.",
      "constraints": [
        "must_be_positive",
        "must_be_finite"
      ]
    },
    "user_intent": {
      "type": "string",
      "allowed_values": [
        "stacking",
        "semi_stack",
        "liquidity"
      ]
    },
    "spot_price_per_g_fine": {
      "type": "number",
      "constraints": [
        "must_be_positive",
        "must_be_finite"
      ],
      "required_if": [
        "shouldManualReview() == false"
      ]
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "quantity": {
      "type": "number",
      "description": "Number of units in the lot.",
      "default": 1,
      "constraints": [
        "must_be_integer",
        "must_be_positive"
      ]
    },
    "source": {
      "type": "string",
      "optional": true
    },
    "raw_title": {
      "type": "string",
      "optional": true,
      "note": "raw_title and ocr_text are not used in the MVP engine flow"
    },
    "ocr_text": {
      "type": "string",
      "optional": true,
      "note": "raw_title and ocr_text are not used in the MVP engine flow"
    }
  },
  "preclassification_flow": {
    "enabled": false,
    "mvp_status": "disabled — future capability, not used in current engine flow",
    "policy_ref": "preclassification_policy.json",
    "steps": [
      "inspect raw_title and/or ocr_text if present",
      "apply preclassification rules",
      "reject obvious non-precious cases before catalog resolution",
      "continue only if no blocking preclassification rule matched"
    ]
  },
  "resolution_rules": {
    "steps": [
      "find family by family_id",
      "find variant by variant_code",
      "load pricing_engine from family.trade_profile",
      "validate required inputs based on pricing_engine",
      "enrich input with catalog data"
    ]
  },
  "resolution_outputs": [
    "family_id",
    "variant_code",
    "metal",
    "series_role",
    "archetype"
  ],
  "derived_fields": {
    "fine_weight_total_g": {
      "description": "Derived from variant.fine_weight_g and quantity in engine code."
    }
  },
  "blocking_error_codes": [
    "invalid_input",
    "missing_required_field",
    "invalid_ask_price",
    "invalid_user_intent",
    "invalid_spot_price",
    "invalid_quantity",
    "unknown_family",
    "unknown_variant",
    "policy_resolution_failed",
    "missing_thresholds_for_archetype"
  ],
  "warning_codes": [],
  "validation_rules": [
    {
      "rule": "family must exist",
      "error_code": "unknown_family"
    },
    {
      "rule": "variant must exist in family",
      "error_code": "unknown_variant"
    },
    {
      "rule": "spot_price_per_g_fine required if shouldManualReview() == false",
      "error_code": "missing_spot_price"
    },
    {
      "rule": "quantity must be >= 1",
      "error_code": "invalid_quantity"
    },
    {
      "rule": "ask_price must be > 0",
      "error_code": "invalid_ask_price"
    },
    {
      "rule": "spot_price_per_g_fine must be > 0 when present",
      "error_code": "invalid_spot_price"
    },
    {
      "rule": "user_intent not supported by family => manual_review",
      "reason_code": "not_reliably_modelled_for_intent"
    }
  ],
  "normalization_rules": {
    "currency": {
      "uppercase": true
    },
    "user_intent": {
      "lowercase": true
    }
  },
  "rejection_policy": {
    "on_blocking_error": "reject_input"
  }
}