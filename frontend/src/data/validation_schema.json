{
  "schema_version": "2.0.0",
  "schema_target": "catalog_version_2.0.0",
  "root_rules": {
    "required_fields": [
      "catalog_version",
      "catalog_scope",
      "base_currency_logic",
      "supported_user_intents",
      "pricing_engines",
      "engine_precision_rules",
      "families"
    ],
    "allowed_catalog_versions": [
      "2.0.0"
    ],
    "allowed_catalog_scope": [
      "secondary_market_fr_observed"
    ],
    "allowed_base_currency_logic": [
      "spot_relative"
    ]
  },
  "pricing_engines_rules": {
    "required_engine_keys": [
      "spot_plus_premium",
      "melt_value",
      "manual_only"
    ]
  },
  "engine_precision_rules_schema": {
    "required_fields": [
      "fine_weight_source",
      "forbid_global_ounce_shortcuts",
      "notes"
    ],
    "allowed_fine_weight_source_values": [
      "variant_field_only"
    ],
    "allowed_forbid_global_ounce_shortcuts_values": [
      true
    ]
  },
  "family_rules": {
    "required_fields": [
      "family_id",
      "identity",
      "trade_profile",
      "supported_intents",
      "media_profile",
      "scan_capability",
      "variants"
    ],
    "identity_rules": {
      "required_fields": [
        "name",
        "aliases",
        "metal",
        "issuer_country",
        "series_role"
      ],
      "allowed_metal_values": [
        "gold",
        "silver"
      ],
      "allowed_series_role_values": [
        "bullion",
        "historical_bullion",
        "semi_bullion",
        "semi_bullion_high_sensitivity",
        "junk_investment"
      ]
    },
    "trade_profile_rules": {
      "required_fields": [
        "pricing_engine",
        "primary_market_position",
        "liquidity_tier",
        "year_sensitivity",
        "condition_sensitivity",
        "collection_sensitivity",
        "auto_verdict_default"
      ],
      "allowed_pricing_engine_values": [
        "spot_plus_premium",
        "melt_value",
        "manual_only"
      ],
      "allowed_primary_market_position_values": [
        "investment",
        "investment_with_collection_sensitivity"
      ],
      "allowed_liquidity_tier_values": [
        "high",
        "medium",
        "low"
      ],
      "allowed_sensitivity_values": [
        "low",
        "medium",
        "high"
      ]
    },
    "media_profile_rules": {
      "required_fields": [
        "has_reference_media",
        "reference_media_strategy",
        "reference_images"
      ]
    },
    "scan_capability_rules": {
      "required_fields": [
        "enabled",
        "scan_confidence_policy",
        "supported_checks"
      ],
      "allowed_scan_confidence_policy_values": [
        "assistive_only"
      ]
    },
    "variants_rules": {
      "required_fields": [
        "variant_code",
        "variant_label",
        "year_from",
        "year_to",
        "gross_weight_g",
        "purity",
        "fine_weight_g",
        "diameter_mm",
        "visual_markers",
        "reference_media"
      ],
      "consistency_rules": [
        "if year_to != null => year_from <= year_to",
        "fine_weight_g must approximately equal gross_weight_g * purity",
        "approximation tolerance = 0.02g"
      ]
    }
  },
  "cross_object_rules": [
    "family_id must be unique",
    "variant_code must be unique within family",
    "trade_profile.pricing_engine must exist in root pricing_engines",
    "each supported_intent must exist in root supported_user_intents",
    "do not infer fine metal weight from oz shortcut; use variant.fine_weight_g only"
  ],
  "sealed_catalog_specific_rules": [
    "silver-american-eagle-family variant 1oz must preserve gross_weight_g = 31.1030, purity = 0.9990, fine_weight_g = 31.0719, diameter_mm = 40.60",
    "gold-maple-leaf-family variant 1oz must preserve diameter_mm = 30.00",
    "gold-kangaroo-family variant 1oz must preserve diameter_mm = 32.60",
    "gold-10f-france-investment-family variant napoleon_iii_laure must preserve gross_weight_g = 3.2258, purity = 0.9000, fine_weight_g = 2.9032, diameter_mm = 19.00",
    "gold-50pesos-mex-family variants must preserve gross_weight_g = 41.6666, purity = 0.9000, fine_weight_g = 37.5000, diameter_mm = 37.00",
    "silver-france-junk-sensitive-family must include 2f_semeuse, 1f_semeuse, 50c_semeuse",
    "silver-panda-family must use pricing_engine = manual_only"
  ],
  "severity_model": {
    "blocking_errors": [
      "missing_required_field",
      "invalid_type",
      "invalid_enum",
      "duplicate_family_id",
      "duplicate_variant_code_within_family",
      "unknown_pricing_engine",
      "invalid_year_range",
      "purity_out_of_range",
      "non_positive_weight",
      "fine_weight_mismatch",
      "invalid_engine_precision_rule",
      "sealed_catalog_constant_broken"
    ],
    "warnings": [
      "diameter_missing",
      "high_collection_sensitivity_with_auto_verdict",
      "high_year_sensitivity_with_auto_verdict",
      "high_condition_sensitivity_with_auto_verdict",
      "aliases_array_too_small",
      "single_variant_family_for_common_bullion_series",
      "missing_reference_media"
    ]
  }
}