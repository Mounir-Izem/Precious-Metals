  "manual_review_rules": {
    "force_manual_if": [
      {
        "condition": "pricing_engine == manual_only",
        "manual_reason": "collection_sensitive_product"
      },
      {
        "condition": "family.trade_profile.collection_sensitivity == high",
        "manual_reason": "high_collection_variability"
      },
      {
        "condition": "family.trade_profile.year_sensitivity == high",
        "manual_reason": "year_dependent_value"
      },
      {
        "condition": "missing_required_inputs == true",
        "manual_reason": "insufficient_data"
      },
      {
        "condition": "invalid_spot_price == true",
        "manual_reason": "invalid_spot_price"
      }
    ]
  },
  "manual_reason_to_verdict_code": {
    "collection_sensitive_product": "manual_engine",
    "high_collection_variability": "manual_collection_sensitivity",
    "year_dependent_value": "manual_year_sensitivity",
    "insufficient_data": "manual_missing_data",
    "invalid_spot_price": "manual_invalid_spot"
  },
  "verdict_mapping": {
    "rules": [
      {
        "condition": "premium_pct < 0",
        "verdict": "good_deal",
        "verdict_code": "below_spot"
      },
      {
        "condition": "premium_pct <= good_deal_max_pct",
        "verdict": "good_deal",
        "verdict_code": "within_good_deal_threshold"
      },
      {
        "condition": "premium_pct <= fair_max_pct",
        "verdict": "fair",
        "verdict_code": "within_fair_threshold"
      },
      {
        "condition": "premium_pct > fair_max_pct",
        "verdict": "expensive",
        "verdict_code": "above_fair_threshold"
      }
    ]
  }
