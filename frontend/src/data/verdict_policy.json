{
  "verdict_policy_version": "1.2.0",
  "policy_scope": "invest_stacking_with_collection_sensitivity",
  "single_threshold_source": "verdict_policy",
  "policy_resolution_order": [
    "family_overrides",
    "intent_thresholds"
  ],
  "supported_verdicts": [
    "good_deal",
    "fair",
    "expensive",
    "manual_review_required"
  ],
  "error_code_registry": [
    "unknown_family",
    "unknown_variant",
    "unsupported_intent",
    "missing_spot_price",
    "invalid_quantity",
    "invalid_ask_price",
    "invalid_spot_price",
    "catalog_resolution_failed",
    "policy_resolution_failed",
    "non_precious_metal_detected",
    "unsupported_non_precious_coin"
  ],
  "pricing_engine_handlers": {
    "spot_plus_premium": {
      "formula": {
        "melt_value": "fine_weight_total_g * spot_price_per_g_fine",
        "premium_value": "ask_price - melt_value",
        "premium_pct": "(premium_value / melt_value) * 100"
      },
      "required_inputs": [
        "ask_price",
        "spot_price_per_g_fine",
        "fine_weight_total_g"
      ]
    },
    "melt_value": {
      "formula": {
        "melt_value": "fine_weight_total_g * spot_price_per_g_fine",
        "premium_value": "ask_price - melt_value",
        "premium_pct": "(premium_value / melt_value) * 100"
      },
      "required_inputs": [
        "ask_price",
        "spot_price_per_g_fine",
        "fine_weight_total_g"
      ]
    },
    "manual_only": {
      "formula": null,
      "required_inputs": [
        "ask_price"
      ]
    }
  },
