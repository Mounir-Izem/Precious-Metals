{
  "verdict_policy_version": "2.0.0",
  "policy_scope": "invest_stacking_with_collection_sensitivity",
  "purpose": "Defines evaluation thresholds, manual review triggers, non-blocking warnings, and explanatory message templates for the price-check engine.",
  "positions": [
    "below_spot",
    "within_range_low",
    "within_range_high",
    "borderline",
    "above_range"
  ],
  "thresholds": {
    "gold": {
      "bullion": {
        "stacking": {
          "low_max": 5,
          "high_max": 10
        },
        "semi_stack": {
          "low_max": 10,
          "high_max": 20
        },
        "liquidity": {
          "low_max": 8,
          "high_max": 15
        }
      },
      "historical_bullion": {
        "stacking": {
          "low_max": 10,
          "high_max": 18
        },
        "semi_stack": {
          "low_max": 15,
          "high_max": 25
        },
        "liquidity": {
          "low_max": 10,
          "high_max": 18
        }
      },
      "semi": {
        "stacking": {
          "low_max": 15,
          "high_max": 25
        },
        "semi_stack": {
          "low_max": 25,
          "high_max": 40
        }
      }
    },
    "silver": {
      "bullion": {
        "stacking": {
          "low_max": 10,
          "high_max": 15
        },
        "semi_stack": {
          "low_max": 15,
          "high_max": 30
        },
        "liquidity": {
          "low_max": 5,
          "high_max": 10,
          "limit_max": 15
        }
      },
      "junk": {
        "stacking": {
          "low_max": 0,
          "high_max": 8
        },
        "semi_stack": {
          "low_max": 8,
          "high_max": 15
        },
        "liquidity": {
          "low_max": 3,
          "high_max": 8
        }
      },
      "semi": {
        "stacking": {
          "low_max": 20,
          "high_max": 35
        },
        "semi_stack": {
          "low_max": 30,
          "high_max": 50
        }
      }
    }
  },
  "manual_review_rules": {
    "trigger_conditions": [
      {
        "field": "pricing_engine",
        "operator": "equals",
        "value": "manual_only",
        "reason_code": "manual_only"
      },
      {
        "field": "collection_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_collection_sensitivity"
      },
      {
        "field": "year_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_year_sensitivity"
      },
      {
        "field": "condition_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_condition_sensitivity"
      }
    ],
    "message_template": "priceCheck.manual_review.message"
  },
  "warning_rules": {
    "unsupported_intent": {
      "behavior": "allow_with_warning",
      "message_template": "priceCheck.warnings.unsupported_intent"
    },
    "missing_thresholds_for_archetype": {
      "behavior": "allow_with_warning",
      "message_template": "priceCheck.warnings.missing_thresholds"
    }
  },
  "message_templates": {
  "below_spot": { "default": "priceCheck.messages.below_spot.default" },
  "within_range_low": {
    "gold": "priceCheck.messages.within_range_low.gold",
    "silver": "priceCheck.messages.within_range_low.silver"
  },
  "within_range_high": {
    "gold": "priceCheck.messages.within_range_high.gold",
    "silver": "priceCheck.messages.within_range_high.silver"
  },
  "borderline": { "default": "priceCheck.messages.borderline.default" },
  "above_range": {
    "gold": "priceCheck.messages.above_range.gold",
    "silver": "priceCheck.messages.above_range.silver"
  }
},
  "engine_notes": [
    "No short verdict labels are exposed to the user.",
    "below_spot is evaluated before threshold comparison.",
    "Threshold resolution depends on metal, archetype, and intent.",
    "manual_review is a runtime status, not a verdict.",
    "Warnings are non-blocking and may coexist with evaluated or manual_review."
  ]
}