{
  "verdict_policy_version": "2.0.0",
  "policy_scope": "secondary_market_fr_observed",
  "purpose": "Defines evaluation thresholds, manual review triggers, and explanatory message templates for the price-check engine.",
  "positions": [
    "below_spot",
    "within_range_low",
    "within_range_high",
    "borderline",
    "above_range"
  ],
  "position_rules": {
    "logic": [
      "premium_pct <= 0 => below_spot",
      "premium_pct <= low_max => within_range_low",
      "premium_pct <= high_max => within_range_high",
      "if limit_max exists and premium_pct <= limit_max => borderline",
      "otherwise => above_range"
    ]
  },
  "thresholds": {
    "gold": {
      "bullion": {
        "stacking":   { "low_max": 5,  "high_max": 9  },
        "semi_stack": { "low_max": 8,  "high_max": 14 },
        "liquidity":  { "low_max": 6,  "high_max": 10 }
      },
      "historical_bullion": {
        "stacking":   { "low_max": 5,  "high_max": 9  },
        "semi_stack": { "low_max": 8,  "high_max": 14 },
        "liquidity":  { "low_max": 6,  "high_max": 10 }
      },
      "semi": {
        "stacking":   { "low_max": 12, "high_max": 20 },
        "semi_stack": { "low_max": 20, "high_max": 32 },
        "liquidity":  { "low_max": 12, "high_max": 20 }
      }
    },
    "silver": {
      "bullion": {
        "stacking":   { "low_max": 10, "high_max": 18 },
        "semi_stack": { "low_max": 15, "high_max": 28 },
        "liquidity":  { "low_max": 10, "high_max": 18, "limit_max": 22 }
      },
      "junk": {
        "stacking":   { "low_max": 0,  "high_max": 8  },
        "semi_stack": { "low_max": 8,  "high_max": 15 },
        "liquidity":  { "low_max": 3,  "high_max": 8  }
      },
      "semi": {
        "stacking":   { "low_max": 18, "high_max": 30 },
        "semi_stack": { "low_max": 25, "high_max": 40 },
        "liquidity":  { "low_max": 12, "high_max": 20, "limit_max": 25 }
      }
    }
  },
  "manual_review_rules": {
    "trigger_conditions": [
      {
        "field": "pricing_engine",
        "operator": "equals",
        "value": "manual_only",
        "reason_code": "manual_only"
      },
      {
        "field": "collection_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_collection_sensitivity"
      },
      {
        "field": "year_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_year_sensitivity"
      },
      {
        "field": "condition_sensitivity",
        "operator": "equals",
        "value": "high",
        "reason_code": "high_condition_sensitivity"
      }
    ],
    "message_template": "priceCheck.manual_review.message"
  },
  "error_rules": {
    "missing_thresholds_for_archetype": {
      "behavior": "error",
      "error_code": "missing_thresholds_for_archetype",
      "message_template": "priceCheck.errors.missing_thresholds"
    }
  },
  "message_templates": {
  "below_spot": { "default": "priceCheck.messages.below_spot.default" },
  "within_range_low": {
    "gold": "priceCheck.messages.within_range_low.gold",
    "silver": "priceCheck.messages.within_range_low.silver"
  },
  "within_range_high": {
    "gold": "priceCheck.messages.within_range_high.gold",
    "silver": "priceCheck.messages.within_range_high.silver"
  },
  "borderline": { "default": "priceCheck.messages.borderline.default" },
  "above_range": {
    "gold": "priceCheck.messages.above_range.gold",
    "silver": "priceCheck.messages.above_range.silver"
  }
},
  "engine_notes": [
    "No short verdict labels are exposed to the user.",
    "below_spot is evaluated before threshold comparison.",
    "Threshold resolution depends on metal, archetype, and intent.",
    "manual_review is a runtime status, not a verdict.",
    "unsupported_intent leads to status=manual_review with reason_code=not_reliably_modelled_for_intent.",
    "unknown archetype leads to status=error with code=policy_resolution_failed.",
    "ask_price is the total lot price, not the unit price.",
    "Thresholds scope: marché secondaire FR observé — not retail dealer, not primary market, not dynamic."
  ]
}