{
  "schema_name": "decision_output_schema",
  "schema_version": "2.0.0",
  "purpose": "Defines the final output contract of the Price-Check engine for all runtime statuses.",
  "top_level_fields": {
    "status": {
      "type": "string",
      "required": true,
      "allowed_values": [
        "incomplete",
        "error",
        "manual_review",
        "evaluated"
      ]
    },
    "product": {
      "type": [
        "object",
        "null"
      ],
      "required": true,
      "description": "Resolved product context when available."
    },
    "pricing": {
      "type": [
        "object",
        "null"
      ],
      "required": true,
      "description": "Computed pricing values. Present only for evaluated and manual_review."
    },
    "analysis": {
      "type": [
        "object",
        "null"
      ],
      "required": true,
      "description": "Interpretive layer of the engine. Present only for evaluated and manual_review."
    },
    "manual_review": {
      "type": [
        "object",
        "null"
      ],
      "required": true,
      "description": "Present only when status = manual_review."
    },
    "warnings": {
      "type": "array",
      "required": true,
      "items_type": "object"
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "required": true,
      "description": "Present only when status = error."
    },
    "missing_fields": {
      "type": "array",
      "required": true,
      "items_type": "string",
      "description": "Present only when status = incomplete, otherwise empty array."
    }
  },
  "shared_objects": {
    "product": {
      "fields": {
        "family_id": {
          "type": [
            "string",
            "null"
          ],
          "required": false
        },
        "variant_code": {
          "type": [
            "string",
            "null"
          ],
          "required": false
        },
        "metal": {
          "type": [
            "string",
            "null"
          ],
          "required": false,
          "allowed_values": [
            "gold",
            "silver"
          ]
        },
        "archetype": {
          "type": [
            "string",
            "null"
          ],
          "required": false,
          "allowed_values": [
            "bullion",
            "historical_bullion",
            "semi",
            "junk",
            "manual_review"
          ]
        }
      }
    },
    "pricing": {
      "fields": {
        "melt_value": {
          "type": "number",
          "required": true
        },
        "premium_value": {
          "type": "number",
          "required": true
        },
        "premium_pct": {
          "type": "number",
          "required": true
        }
      }
    },
    "analysis_evaluated": {
      "fields": {
        "intent": {
          "type": "string",
          "required": true,
          "allowed_values": [
            "stacking",
            "semi_stack",
            "liquidity"
          ]
        },
        "position": {
          "type": "string",
          "required": true,
          "allowed_values": [
            "below_spot",
            "within_range_low",
            "within_range_high",
            "borderline",
            "above_range"
          ]
        },
        "message": {
          "type": "string",
          "required": true
        }
      }
    },
    "analysis_manual_review": {
      "fields": {
        "intent": {
          "type": "string",
          "required": true,
          "allowed_values": [
            "stacking",
            "semi_stack",
            "liquidity"
          ]
        },
        "message": {
          "type": "string",
          "required": true
        }
      }
    },
    "manual_review": {
      "fields": {
        "reason_code": {
          "type": "string",
          "required": true,
          "allowed_values": [
            "manual_only",
            "high_collection_sensitivity",
            "high_year_sensitivity",
            "high_condition_sensitivity",
            "not_reliably_modelled_for_intent"
          ]
        }
      }
    },
    "warning": {
      "fields": {
        "code": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "string",
          "required": true
        }
      }
    },
    "error": {
      "fields": {
        "code": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "string",
          "required": true
        }
      }
    }
  },
  "status_rules": {
    "incomplete": {
      "product": "object_or_null",
      "pricing": null,
      "analysis": null,
      "manual_review": null,
      "warnings": [],
      "error": null,
      "missing_fields": "non_empty_array"
    },
    "error": {
      "product": "object_or_null",
      "pricing": null,
      "analysis": null,
      "manual_review": null,
      "warnings": [],
      "error": "required_object",
      "missing_fields": []
    },
    "manual_review": {
      "product": "required_object",
      "pricing": "required_object",
      "analysis": "required_object_matching_analysis_manual_review",
      "manual_review": "required_object",
      "warnings": "array",
      "error": null,
      "missing_fields": []
    },
    "evaluated": {
      "product": "required_object",
      "pricing": "required_object",
      "analysis": "required_object_matching_analysis_evaluated",
      "manual_review": null,
      "warnings": "array",
      "error": null,
      "missing_fields": []
    }
  },
  "engine_notes": [
    "manual_review is a runtime status, not a verdict.",
    "No short verdict labels are exposed to the user in this schema.",
    "User-facing interpretation is carried by analysis.position + analysis.message.",
    "Pricing remains visible in manual_review.",
    "Warnings are non-blocking and may coexist with evaluated or manual_review."
  ]
}